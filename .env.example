# Required: OpenAI API key
GATEWAY_PROVIDERS__OPENAI__API_KEY=sk-your-key-here

# Optional: Override config values via environment variables.
# Use double underscore (__) to separate hierarchy levels.
# GATEWAY_SERVER__PORT=8080
# GATEWAY_SERVER__READ_TIMEOUT=30s
# GATEWAY_SERVER__WRITE_TIMEOUT=120s
# GATEWAY_PROVIDERS__OPENAI__BASE_URL=https://api.openai.com/v1
# GATEWAY_PROVIDERS__OPENAI__TIMEOUT=30s
# GATEWAY_LOG__LEVEL=debug
# GATEWAY_LOG__FORMAT=json
# GATEWAY_LOG__DEBUG_BODIES=false

# Override config file path (default: configs/gateway.yaml)
# GATEWAY_CONFIG_PATH=configs/gateway.yaml
